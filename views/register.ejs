<%- include('partials/header', { title: 'Register' }) %>
<%- include('partials/nav') %>
<main class="container py-5">
    <section class="mx-auto theme-card rounded-3 shadow-sm p-4 p-md-5 auth-card">
        <h1 class="h2 mb-3">Register</h1>
        <p class="mb-4">TodoShell のアカウントを作成してください。</p>

        <form action="/register" method="POST" class="d-grid gap-3">
            <div>
                <label for="username" class="form-label">Username</label>
                <input
                    type="text"
                    id="username"
                    name="username"
                    class="form-control"
                    placeholder="username"
                    required
                >
            </div>

            <div>
                <label for="password" class="form-label">Password</label>
                <input
                    type="password"
                    id="password"
                    name="password"
                    class="form-control"
                    placeholder="password"
                    required
                >
            </div>

            <button type="submit" class="btn btn-primary">Create account</button>
        </form>

        <p class="mb-0 auth-helper-text">
            すでにアカウントがある場合は
            <a href="/login" class="auth-link">ログインページへ</a>
        </p>
    </section>
</main>
<%- include('partials/footer') %>
